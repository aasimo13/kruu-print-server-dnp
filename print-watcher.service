[Unit]
Description=KRUU Print Hot Folder Watcher
After=cups.service
Requires=cups.service

[Service]
# __USER__ and the paths below are filled in by install.sh at install time.
ExecStart=__APP_DIR__/print-watcher.sh
Environment=HOTFOLDER_ROOT=__HOTFOLDER_ROOT__
Restart=always
RestartSec=5
User=__USER__

[Install]
WantedBy=multi-user.target
